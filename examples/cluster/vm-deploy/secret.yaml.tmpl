apiVersion: v1
kind: Secret
metadata:
  name: vsphere-creds
  namespace: crossplane-system
type: Opaque
stringData:
  # IMPORTANT: the key MUST be "user", NOT "username".
  # internal/clients/vsphere.go reads creds["user"]; a wrong key passes an
  # empty user to the terraform vSphere provider and vCenter then rejects the
  # login with the misleading error:
  #   ServerFaultCode: Cannot complete login due to an incorrect user name or password
  credentials: |
    {
      "user": "${VSPHERE_USER}",
      "password": "${VSPHERE_PASSWORD}",
      "server": "${VSPHERE_SERVER}",
      "allow_unverified_ssl": "true"
    }

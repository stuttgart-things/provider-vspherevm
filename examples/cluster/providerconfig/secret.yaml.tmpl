apiVersion: v1
kind: Secret
metadata:
  name: example-creds
  namespace: crossplane-system
type: Opaque
stringData:
  # NOTE: the key is "user" (NOT "username") — internal/clients/vsphere.go reads
  # creds["user"]. A wrong key sends an empty user and vCenter rejects the login
  # with "Cannot complete login due to an incorrect user name or password".
  credentials: |
    {
      "user": "administrator@vsphere.local",
      "password": "t0ps3cr3t11",
      "server": "vcenter.example.com",
      "allow_unverified_ssl": "true"
    }
